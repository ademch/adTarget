prefix=c:/
includedir=${prefix}/include
libdir=${prefix}/lib

Name: ffms2
Description: The Fabulous FM Library 2
Version: 5.1.2
Requires.private: libavformat >= 61.7.0, libavcodec >= 61.19.0, libswscale >= 8.3.0, libavutil >= 59.39.0, libswresample >= 5.3.0, zlib
Libs: -L${libdir} -lffms2
Cflags: -I${includedir}
